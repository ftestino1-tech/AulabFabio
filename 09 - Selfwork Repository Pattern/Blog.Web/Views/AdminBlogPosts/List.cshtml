@using Blog.Web.Models.Domain
@model IEnumerable<Blog.Web.Models.Domain.BlogPost>

<div class="bg-secondary bg-opacity-10 py-2">
    <div class="container">
        <h1>All Blog Posts</h1>
    </div>
</div>

@if (TempData[key: "SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData[key: "SuccessMessage"]
    </div>
}


<div class="container py-5">
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Heading</th>
                <th>Tags</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var BlogPost BlogPost in Model)
            {
                <tr>
                    <td>@blogPost.Id</td>
                    <td>@blogPost.Heading</td>
                    <th>Actions</th>
                    <td>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var Tag tag in blogPost.Tags)
                            {
                                <span class="badge bg-secondary">
                                    @tag.Name
                                </span>
                            }
                        </div>
                    </td>
                    <td>
                        <a class="btn btn-warning" asp-controller="AdminBlogPosts" asp-action="Edit"
                        asp-route-id="@blogPost.Id">
                        Edit
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>