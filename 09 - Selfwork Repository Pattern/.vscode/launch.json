{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "ASP.NET Core (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Blog.Web/bin/Debug/net10.0/Blog.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Blog.Web",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5019"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
        }
    ]   
}